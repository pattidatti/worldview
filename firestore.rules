rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function killSwitchOn() {
      return exists(/databases/$(database)/documents/config/killSwitch)
             && get(/databases/$(database)/documents/config/killSwitch).data.disabled == true;
    }

    // Kill-switch-config: leses av alle innloggede, ingen kan skrive via klient (gjøres fra Firebase Console).
    match /config/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Gates: globalt delt read, eier kan write/delete.
    match /gates/{gateId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && !killSwitchOn()
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.schemaVersion == 1;
      allow update: if request.auth != null
                    && !killSwitchOn()
                    && resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null
                    && !killSwitchOn()
                    && resource.data.ownerUid == request.auth.uid;
    }

    // Snapshots: globalt delt read, alle innloggede kan skrive med korrekt schemaVersion.
    match /snapshots/{day}/entries/{epochMinute} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                            && !killSwitchOn()
                            && request.resource.data.schemaVersion == 1;
      allow delete: if false; // TTL rydder opp
    }

    // Entity-snapshots (fly, skip, disasters, news): globalt delt read.
    // Writes kun fra Cloud Functions via admin SDK (rules bypasses for admin).
    match /entities/{entityType}/buckets/{bucketId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Gate-crossings: globalt delt read, enhver innlogget kan skrive med korrekt schemaVersion.
    // Idempotens via deterministisk doc-ID (gateId_entityId_segmentIndex_tsMinute).
    match /gate_crossings/{day}/events/{crossingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && !killSwitchOn()
                    && request.resource.data.schemaVersion == 1;
      allow update: if false;
      allow delete: if false; // TTL rydder opp
    }

    // Alt annet — default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
